# Globalify — environment configuration example
#
# Copy this file to `.env` and fill in values. `.env` is gitignored — never commit real secrets.
# Most integrations are OPTIONAL and "flip-live" by adding credentials: until set, the app
# degrades gracefully (email logs instead of sending, R2 falls back to local disk, captcha
# is skipped, the Paddle/ads UI shows "coming soon"). The suite runs with NONE of these set.
#
# Config is loaded by src/project/config.py (typed pydantic-settings). Many keys use a
# leading-underscore prefix, which is a project convention — keep it.

# ─────────────────────────────────────────────────────────────────────────────
# Core (required)
# ─────────────────────────────────────────────────────────────────────────────

# Runtime mode: production | testing | debug
FLASK_ENV=debug

# REQUIRED — no default; the app fails fast at startup if unset.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# SQLAlchemy connection string. Default (if unset): sqlite:///db.sqlite
# Postgres example: postgresql+psycopg://user:password@localhost:5432/globalify
_DATABASE_URL=sqlite:///db.sqlite

# Connection pool tuning (optional; sane defaults shown)
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_POOL_RECYCLE=1800

# ─────────────────────────────────────────────────────────────────────────────
# Search — Typesense (required for browse/search; defaults target local Docker)
# Run locally:
#   docker run -p 8108:8108 -v $(pwd)/typesense-data:/data \
#     typesense/typesense:30.2 --data-dir /data --api-key=xyz --enable-cors
# ─────────────────────────────────────────────────────────────────────────────

_TYPESENSE_HOST=127.0.0.1
_TYPESENSE_PORT=8108
_TYPESENSE_API_KEY=xyz

# App-side embeddings for hybrid vector + keyword search.
# Default "none" = keyword-only (no key required).
# Set to "gemini" and supply GEMINI_API_KEY to enable semantic search.
# After changing provider or _EMBEDDING_DIM you MUST recreate the collection
# and reindex: flask setup (or sync_search_index(recreate=True)).
_EMBEDDING_PROVIDER=none
GEMINI_API_KEY=
_EMBEDDING_MODEL=gemini-embedding-001
_EMBEDDING_DIM=768
_EMBEDDING_DISTANCE_THRESHOLD=0.30

# ─────────────────────────────────────────────────────────────────────────────
# Email — Resend (optional; logs the message instead of sending when unset)
# ─────────────────────────────────────────────────────────────────────────────

_RESEND_API_KEY=
# Verified sender. Default: "Globalify <noreply@mail.globalify.xyz>"
_EMAIL_FROM=Globalify <noreply@mail.globalify.xyz>

# ─────────────────────────────────────────────────────────────────────────────
# Image storage — Cloudflare R2 (optional; falls back to local instance/uploads/ when unset)
# All four credential vars must be set together to enable R2.
# ─────────────────────────────────────────────────────────────────────────────

_R2_ACCOUNT_ID=
_R2_ACCESS_KEY_ID=
_R2_SECRET_ACCESS_KEY=
_R2_BUCKET=
# Public custom domain serving the bucket, e.g. images.globalify.xyz (no scheme)
_R2_PUBLIC_DOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# Captcha — Cap, self-hosted (optional; verification is SKIPPED when unset,
# and fails CLOSED once configured). Endpoint + secret are required to enable.
# See docs/cap-selfhosting.md.
# ─────────────────────────────────────────────────────────────────────────────

_CAP_API_ENDPOINT=
_CAP_SITE_KEY=
_CAP_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Billing — Paddle (optional; checkout UI shows "coming soon" until configured).
# Webhook signature verification activates as soon as _PADDLE_WEBHOOK_SECRET is set.
# Point the Paddle dashboard webhook at: /payment/webhook
# ─────────────────────────────────────────────────────────────────────────────

_PADDLE_CLIENT_TOKEN=
_PADDLE_PRICE_ID_MONTHLY=
_PADDLE_PRICE_ID_LIFETIME=
_PADDLE_API_KEY=
_PADDLE_WEBHOOK_SECRET=
# sandbox | production
_PADDLE_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────────────────────────────────────
# Ads (optional; ad slots shown to non-Pro viewers only when enabled)
# ─────────────────────────────────────────────────────────────────────────────

_ADS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# Data collectors — SEC EDGAR
# SEC fair-access policy requires a descriptive User-Agent with contact info.
# ─────────────────────────────────────────────────────────────────────────────

_EDGAR_USER_AGENT=Globalify Directory contact@globalify.xyz

# ─────────────────────────────────────────────────────────────────────────────
# Observability (optional)
# ─────────────────────────────────────────────────────────────────────────────

_SENTRY_DSN=
_POSTHOG_API_KEY=
